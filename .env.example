# ===========================================================================
# Remote CNC – Environment variables
# ===========================================================================
# Copy this file to .env and fill in the values.
# This single file is used by both docker-compose and the Python app.
# ===========================================================================

# DB configuration
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
# Local development: localhost | Inside docker-compose: postgresql
DB_HOST=localhost

# Redis
# Local development: localhost | Inside docker-compose: redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_CELERY=0
REDIS_DB_STORAGE=1

# API server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Serial communication configuration
### Port name:
### - On Windows: 'COM1', 'COM2', etc.
### - On macOS: '/dev/cu.usbmodem*' or '/dev/tty.usbmodem*'
### - On Linux: '/dev/ttyUSB0' or '/dev/ttyACM0'
SERIAL_PORT=
SERIAL_BAUDRATE=115200

# Location of GCODE files, thumbnails, and logs
FILES_FOLDER_PATH=/app/gcode_files
IMAGES_FOLDER_PATH=/app/thumbnails
LOGS_FOLDER_PATH=/app/logs

# User authentication
TOKEN_SECRET=any-64-character-ultra-secure-randomly-generated-secret

# Ngrok configuration (optional)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
